		{
			"name": "Appointment Tools",
			"item": [
				{
					"name": "Create Appointment",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"create_appointment\",\n        \"arguments\": {\n            \"patient_id\": \"patient-001\",\n            \"slot_id\": \"slot-011\",\n            \"reason\": \"Skin rash consultation\"\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/mcp",
							"host": ["{{baseUrl}}"],
							"path": ["mcp"]
						},
						"description": "Create an appointment for a patient.\n\n**Arguments:**\n- `patient_id` (string): Patient ID from search_patients or create_patient\n- `slot_id` (string): Slot ID from get_available_slots\n- `reason` (string, optional): Reason for the appointment\n\n**Returns:**\n- `success` (boolean): Whether booking succeeded\n- `appointment_id` (string): Appointment ID for future reference\n- `date`, `time`: Appointment details"
					}
				},
				{
					"name": "Create Appointment - Without Reason",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"create_appointment\",\n        \"arguments\": {\n            \"patient_id\": \"patient-002\",\n            \"slot_id\": \"slot-012\"\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/mcp",
							"host": ["{{baseUrl}}"],
							"path": ["mcp"]
						},
						"description": "Create an appointment without specifying a reason (reason is optional)."
					}
				},
				{
					"name": "Update Appointment (Reschedule)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"update_appointment\",\n        \"arguments\": {\n            \"appointment_id\": \"{{appointment_id}}\",\n            \"new_slot_id\": \"slot-013\"\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/mcp",
							"host": ["{{baseUrl}}"],
							"path": ["mcp"]
						},
						"description": "Reschedule an existing appointment to a new time slot.\n\n**Arguments:**\n- `appointment_id` (string): Existing appointment ID to reschedule\n- `new_slot_id` (string): New slot ID from get_available_slots\n\n**Returns:**\n- `success` (boolean): Whether reschedule succeeded\n- `old_date`, `old_time`: Previous appointment time\n- `new_date`, `new_time`: New appointment time\n\n**Note:** Replace `{{appointment_id}}` with the actual ID from create_appointment response."
					}
				}
			]
		},
