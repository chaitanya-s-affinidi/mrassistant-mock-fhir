{
	"info": {
		"_postman_id": "hospital-mcp-tools-collection",
		"name": "Hospital MCP Tools",
		"description": "MCP tool calls for the Hospital FHIR appointment booking system.\n\nBase URL: http://localhost:3000/mcp\n\nAll requests use JSON-RPC 2.0 format with method `tools/call`.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Patient Tools",
			"item": [
				{
					"name": "Search Patient",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"search_patients\",\n        \"arguments\": {\n            \"name\": \"Camila Lopez\",\n            \"birth_date\": \"1985-03-15\"\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/mcp",
							"host": ["{{baseUrl}}"],
							"path": ["mcp"]
						},
						"description": "Search for a patient by name and date of birth.\n\n**Arguments:**\n- `name` (string): Patient's full name (first and last)\n- `birth_date` (string): Date of birth in YYYY-MM-DD format\n\n**Returns:**\n- `found` (boolean): Whether patient was found\n- `patient_id` (string): Patient ID for use in appointments\n- `name`, `birth_date`, `phone`: Patient details"
					}
				},
				{
					"name": "Search Patient - Not Found",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"search_patients\",\n        \"arguments\": {\n            \"name\": \"John Doe\",\n            \"birth_date\": \"1990-01-01\"\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/mcp",
							"host": ["{{baseUrl}}"],
							"path": ["mcp"]
						},
						"description": "Example of searching for a patient that doesn't exist."
					}
				},
				{
					"name": "Create Patient",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"create_patient\",\n        \"arguments\": {\n            \"name\": \"John Doe\",\n            \"birth_date\": \"1990-06-15\",\n            \"phone\": \"+6598765432\"\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/mcp",
							"host": ["{{baseUrl}}"],
							"path": ["mcp"]
						},
						"description": "Create a new patient record.\n\n**Arguments:**\n- `name` (string): Patient's full name (first and last)\n- `birth_date` (string): Date of birth in YYYY-MM-DD format\n- `phone` (string): Phone number with country code (e.g., +6591234567)\n\n**Returns:**\n- `success` (boolean): Whether creation succeeded\n- `patient_id` (string): New patient ID for use in appointments"
					}
				}
			]
		},
